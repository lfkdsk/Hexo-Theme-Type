<section class="pjax-area">
  <div class="content-area animals-area">
    <% if (theme.photography_page.slogan == true) { %>
    <div id="animals-slogan" class="animals-slogan">
      <%- (typeof config.animals_page !== 'undefined' && config.animals_page.slogan_descr) || '动物图鉴 / Animal Atlas' %>
    </div>
    <% } %>
    <div id="animals-stats" class="animals-stats"></div>

    <div id="animals-detail" class="animals-detail-bar" style="display:none;">
      <a id="animals-back" class="animals-back" href="javascript:void(0)">&larr; 全部动物 / All</a>
      <div class="animals-detail-title">
        <span id="animals-detail-zh"></span>
        <span id="animals-detail-en"></span>
      </div>
      <div id="animals-detail-meta" class="animals-detail-meta"></div>
    </div>

    <div class="animals-map-frame">
      <div id="animals-map"></div>
    </div>

    <div id="animals-grid" class="animals-grid grid grid-cols-1 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"></div>

    <div id="animals-photos" class="animals-photos grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5" style="display:none;"></div>
  </div>

  <style>
    body { background-color: #fbf9f4; }
    .animals-area {
      margin: 120px auto 60px;
      padding: 0 16px;
      max-width: 1240px;
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }
    .animals-slogan {
      text-align: center;
      font-size: 36px;
      font-weight: 700;
      letter-spacing: .02em;
      color: #2f3a2f;
      font-family: Georgia, "Source Han Serif", "Noto Serif SC", serif;
    }
    .animals-stats {
      margin-top: 12px;
      font-size: 13px;
      color: #6b7060;
      text-align: center;
      font-feature-settings: "tnum";
    }

    /* map */
    .animals-map-frame {
      position: relative;
      margin-top: 28px;
      padding: 14px;
      background: #f1ece1;
      background-image:
        linear-gradient(rgba(120,110,90,.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(120,110,90,.08) 1px, transparent 1px);
      background-size: 24px 24px;
      border-radius: 2px;
    }
    .animals-map-frame::before,
    .animals-map-frame::after,
    .animals-map-frame > .corner-tl,
    .animals-map-frame > .corner-br {
      content: '';
      position: absolute;
      width: 16px; height: 16px;
      border: 1.5px solid #2f3a2f;
    }
    .animals-map-frame::before { top: 4px; left: 4px; border-right: 0; border-bottom: 0; }
    .animals-map-frame::after  { top: 4px; right: 4px; border-left: 0;  border-bottom: 0; }
    .animals-map-frame > .corner-tl { bottom: 4px; left: 4px; border-right: 0; border-top: 0; }
    .animals-map-frame > .corner-br { bottom: 4px; right: 4px; border-left: 0; border-top: 0; }
    #animals-map {
      height: 60vh;
      width: 100%;
      background: #ece6d8;
    }
    .leaflet-container { background: transparent; font-family: inherit; }
    .animals-map-frame .leaflet-top,
    .animals-map-frame .leaflet-bottom { z-index: 400; }
    .leaflet-control-attribution {
      background: rgba(251,249,244,.85) !important;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 10px !important;
      color: #5c5546 !important;
    }
    .leaflet-control-attribution a { color: #2f3a2f !important; }
    .leaflet-bar a {
      background-color: #fbf9f4 !important;
      color: #2f3a2f !important;
      border-color: #d8d2c3 !important;
    }
    .leaflet-bar a:hover { background-color: #f1ece1 !important; }
    .leaflet-control-scale-line {
      background: rgba(251,249,244,.85);
      border: 1px solid #2f3a2f;
      border-top: none;
      color: #2f3a2f;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 10px;
      letter-spacing: .04em;
    }

    /* cluster marker */
    .animals-cluster {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 26px; height: 26px;
      border-radius: 50%;
      background: #6b8e4e;
      color: #fbf9f4;
      font-family: Georgia, serif;
      font-size: 12px;
      font-weight: 700;
      border: 2px solid #fbf9f4;
      box-shadow: 0 1px 2px rgba(0,0,0,.25);
    }
    .animals-cluster.solo {
      width: 14px; height: 14px;
      font-size: 0;
    }

    /* popup */
    .leaflet-popup-content-wrapper {
      background: #fbf9f4;
      border-radius: 2px;
      box-shadow: 0 1px 0 rgba(0,0,0,.08), 0 4px 14px rgba(40,40,30,.10);
      border: 1px solid #d8d2c3;
    }
    .leaflet-popup-tip { background: #fbf9f4; border-left: 1px solid #d8d2c3; border-bottom: 1px solid #d8d2c3; }
    .leaflet-popup-content { margin: 0; min-width: 240px; }
    .leaflet-popup-close-button { display: none; }
    .animals-popup { font-family: Georgia, "Source Han Serif", "Noto Serif SC", serif; color: #2f3a2f; }
    .animals-popup-img {
      width: 100%; aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      background: #ece6d8;
    }
    .animals-popup-nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 10px;
      gap: 8px;
      border-bottom: 1px dashed #d8d2c3;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 11px;
      letter-spacing: .04em;
    }
    .animals-popup-nav button {
      background: #fbf9f4;
      border: 1px solid #2f3a2f;
      color: #2f3a2f;
      padding: 3px 10px;
      font-family: inherit;
      font-size: 11px;
      cursor: pointer;
      letter-spacing: .04em;
    }
    .animals-popup-nav button:hover { background: #f1ece1; }
    .animals-popup-nav button[disabled] { color: #b6b3a8; border-color: #d8d2c3; cursor: default; }
    .animals-popup-nav .pos {
      background: #2f3a2f;
      color: #fbf9f4;
      padding: 3px 10px;
      font-size: 11px;
    }
    .animals-popup-body { padding: 10px 12px 12px; }
    .animals-popup-zh { font-size: 16px; font-weight: 700; line-height: 1.25; }
    .animals-popup-en { font-style: italic; color: #6b7060; font-size: 13px; line-height: 1.3; margin-top: 2px; }
    .animals-popup-coord {
      margin-top: 8px;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 11px;
      color: #6b7060;
      letter-spacing: .02em;
    }
    .animals-popup-link {
      margin-top: 10px;
      display: inline-block;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 11px;
      color: #2f3a2f;
      text-decoration: none;
      letter-spacing: .04em;
      border-bottom: 1px solid #2f3a2f;
      padding-bottom: 1px;
    }
    .animals-popup-link:hover { background: #f1ece1; }

    /* grid + photos */
    .animals-grid { margin-top: 32px; gap: 10px; width: 100%; }
    .animals-photos { margin-top: 24px; gap: 8px; width: 100%; }
    .animals-card {
      position: relative;
      aspect-ratio: 3 / 2;
      background-position: center;
      background-size: cover;
      background-color: #ece6d8;
      cursor: pointer;
      transition: transform .15s ease-in-out, box-shadow .15s ease-in-out;
      border: 1px solid #d8d2c3;
    }
    .animals-card:hover { box-shadow: 0 4px 14px rgb(0 0 0 / 14%); transform: translateY(-1px); }
    .animals-card-info {
      position: absolute; left: 0; right: 0; bottom: 0;
      padding: 10px 12px;
      color: #fbf9f4;
      background: linear-gradient(transparent, rgba(0,0,0,.7));
      line-height: 1.3;
      font-family: Georgia, "Source Han Serif", "Noto Serif SC", serif;
    }
    .animals-card-zh { font-weight: 700; font-size: 15px; }
    .animals-card-en { display: block; font-style: italic; opacity: .85; font-size: 11px; margin-top: 2px; }
    .animals-card-count {
      position: absolute; top: 8px; right: 8px;
      background: rgba(47,58,47,.85);
      color: #fbf9f4;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 11px;
      padding: 2px 8px;
    }
    .animals-card-pin {
      position: absolute; top: 8px; left: 8px;
      background: rgba(107,142,78,.92);
      color: #fbf9f4;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 11px;
      padding: 2px 6px;
    }
    .animals-photo-tile {
      aspect-ratio: 1 / 1;
      background-position: center;
      background-size: cover;
      background-color: #ece6d8;
      cursor: pointer;
      transition: transform .15s ease-in-out;
      border: 1px solid #d8d2c3;
    }
    .animals-photo-tile:hover { transform: scale(1.02); }

    /* detail bar */
    .animals-detail-bar {
      margin-top: 28px;
      width: 100%;
      display: flex;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
      padding-bottom: 10px;
      border-bottom: 1px solid #d8d2c3;
    }
    .animals-back {
      color: #6b8e4e;
      font-size: 13px;
      text-decoration: none;
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      letter-spacing: .04em;
    }
    .animals-back:hover { text-decoration: underline; }
    .animals-detail-title {
      font-family: Georgia, "Source Han Serif", "Noto Serif SC", serif;
      font-weight: 700; font-size: 22px; color: #2f3a2f;
    }
    .animals-detail-title #animals-detail-en {
      font-weight: 400; font-style: italic; font-size: 14px; color: #6b7060; margin-left: 8px;
    }
    .animals-detail-meta {
      font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      font-size: 12px; color: #6b7060;
    }

    @media (max-width: 768px) {
      .animals-area { margin-top: 80px; }
      .animals-slogan { font-size: 28px; }
      #animals-map { height: 50vh; }
      .leaflet-popup-content { min-width: 180px; }
    }
    @media (prefers-color-scheme: dark) {
      body { background-color: #14181a; }
      .animals-slogan { color: #e6e0d0; }
      .animals-stats { color: #9aa094; }

      .animals-map-frame {
        background: #1d2326;
        background-image:
          linear-gradient(rgba(220,210,180,.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(220,210,180,.05) 1px, transparent 1px);
      }
      .animals-map-frame::before,
      .animals-map-frame::after,
      .animals-map-frame > .corner-tl,
      .animals-map-frame > .corner-br {
        border-color: #d4cdb8;
      }
      #animals-map { background: #11171a; }
      /* invert OSM tiles so they fit a dark canvas */
      .leaflet-layer,
      .leaflet-control-zoom-in,
      .leaflet-control-zoom-out {
        filter: invert(100%) hue-rotate(180deg) brightness(92%) contrast(95%);
      }
      .leaflet-control-attribution {
        background: rgba(20,24,26,.85) !important;
        color: #9aa094 !important;
      }
      .leaflet-control-attribution a { color: #c8d0a8 !important; }
      .leaflet-bar a {
        background-color: #1d2326 !important;
        color: #e6e0d0 !important;
        border-color: #3a3f3a !important;
      }
      .leaflet-bar a:hover { background-color: #262d31 !important; }
      .leaflet-control-scale-line {
        background: rgba(20,24,26,.85);
        border-color: #d4cdb8;
        color: #d4cdb8;
      }

      .animals-cluster { background: #9bba75; color: #14181a; border-color: #14181a; }

      .leaflet-popup-content-wrapper {
        background: #1d2326;
        border-color: #3a3f3a;
        box-shadow: 0 1px 0 rgba(0,0,0,.4), 0 4px 14px rgba(0,0,0,.45);
      }
      .leaflet-popup-tip { background: #1d2326; border-color: #3a3f3a; }
      .animals-popup { color: #e6e0d0; }
      .animals-popup-img { background: #11171a; }
      .animals-popup-nav { border-bottom-color: #3a3f3a; }
      .animals-popup-nav button {
        background: #1d2326; color: #e6e0d0; border-color: #d4cdb8;
      }
      .animals-popup-nav button:hover { background: #262d31; }
      .animals-popup-nav button[disabled] { color: #6c7060; border-color: #3a3f3a; }
      .animals-popup-nav .pos { background: #d4cdb8; color: #14181a; }
      .animals-popup-en { color: #9aa094; }
      .animals-popup-coord { color: #9aa094; }
      .animals-popup-link { color: #c8d0a8; border-bottom-color: #c8d0a8; }
      .animals-popup-link:hover { background: #262d31; }

      .animals-card { background-color: #1d2326; border-color: #3a3f3a; }
      .animals-card-count { background: rgba(212,205,184,.92); color: #14181a; }
      .animals-card-pin { background: rgba(155,186,117,.92); color: #14181a; }
      .animals-photo-tile { background-color: #1d2326; border-color: #3a3f3a; }

      .animals-detail-bar { border-bottom-color: #3a3f3a; }
      .animals-detail-title { color: #e6e0d0; }
      .animals-detail-title #animals-detail-en { color: #9aa094; }
      .animals-detail-meta { color: #9aa094; }
      .animals-back { color: #c8d0a8; }
    }
  </style>

  <script type="text/javascript">
    (function () {
      var animals = JSON.parse(`<%- JSON.stringify(site.data.animals || []) %>`);
      var fullUrl = '<%- full_url_for() %>';

      function getParam(key) {
        return new URLSearchParams(window.location.search).get(key);
      }
      function setParam(key, value) {
        var url = new URL(window.location.href);
        if (value === null || value === undefined) url.searchParams.delete(key);
        else url.searchParams.set(key, value);
        window.history.replaceState({}, '', url.toString());
      }
      function findSpecies(key) {
        if (!key) return null;
        for (var i = 0; i < animals.length; i++) if (animals[i].key === key) return animals[i];
        return null;
      }
      function escHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }
      function fmtCoord(loc) {
        var lat = loc[0], lon = loc[1];
        return Math.abs(lat).toFixed(4) + '° ' + (lat >= 0 ? 'N' : 'S')
             + ', '
             + Math.abs(lon).toFixed(4) + '° ' + (lon >= 0 ? 'E' : 'W');
      }

      // bucket photos within ~100m so overlapping markers collapse to a single, navigable cluster.
      function bucketKey(loc) {
        return Math.round(loc[0] * 1000) + ',' + Math.round(loc[1] * 1000);
      }
      function buildClusters(species) {
        var clusters = {};
        var sources = species ? [species] : animals;
        for (var s = 0; s < sources.length; s++) {
          var sp = sources[s];
          for (var i = 0; i < sp.photos.length; i++) {
            var ph = sp.photos[i];
            if (!ph.location || ph.location.length !== 2) continue;
            var k = bucketKey(ph.location);
            if (!clusters[k]) clusters[k] = { loc: ph.location, items: [] };
            clusters[k].items.push({ species: sp, photo: ph });
          }
        }
        return clusters;
      }

      function clusterIcon(count) {
        var cls = 'animals-cluster' + (count <= 1 ? ' solo' : '');
        var label = count > 1 ? count : '';
        return L.divIcon({
          className: '',
          html: '<div class="' + cls + '">' + label + '</div>',
          iconSize: count > 1 ? [26, 26] : [14, 14],
          iconAnchor: count > 1 ? [13, 13] : [7, 7]
        });
      }

      function popupContent(items, idx) {
        var item = items[idx];
        var sp = item.species, ph = item.photo;
        var albumLink = fullUrl + ph.dir + '?name=' + encodeURIComponent(ph.name);
        var prevDis = items.length <= 1 ? ' disabled' : '';
        var nextDis = prevDis;
        var nav = '<div class="animals-popup-nav">'
                + '<button data-step="-1"' + prevDis + '>◀ PREV</button>'
                + '<span class="pos">' + (idx + 1) + ' / ' + items.length + '</span>'
                + '<button data-step="1"' + nextDis + '>NEXT ▶</button>'
                + '</div>';
        return '<div class="animals-popup">'
             + nav
             + '<img class="animals-popup-img" src="' + escHtml(ph.thum) + '" />'
             + '<div class="animals-popup-body">'
               + '<div class="animals-popup-zh">' + escHtml(sp.zh) + '</div>'
               + (sp.en ? '<div class="animals-popup-en">' + escHtml(sp.en) + '</div>' : '')
               + '<div class="animals-popup-coord">' + escHtml(fmtCoord(ph.location)) + '</div>'
               + '<a class="animals-popup-link" href="' + escHtml(albumLink) + '" target="_blank">查看相册 / Open Album</a>'
             + '</div>'
             + '</div>';
      }

      function wirePopupNav(popup, items, idx) {
        var el = popup.getElement();
        if (!el) return;
        // stop any click inside the popup from reaching the map (which would close it).
        var nav = el.querySelector('.animals-popup-nav');
        if (nav) L.DomEvent.disableClickPropagation(nav);
        var btns = el.querySelectorAll('.animals-popup-nav button');
        btns.forEach(function (b) {
          L.DomEvent.on(b, 'click', function (ev) {
            L.DomEvent.stop(ev);
            if (b.hasAttribute('disabled')) return;
            var step = parseInt(b.getAttribute('data-step'), 10);
            var next = (idx + step + items.length) % items.length;
            popup.setContent(popupContent(items, next));
            setTimeout(function () { wirePopupNav(popup, items, next); }, 0);
          });
        });
      }

      var map = L.map('animals-map', { zoomControl: false, scrollWheelZoom: true });
      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
      }).addTo(map);
      L.control.zoom({ position: 'topright' }).addTo(map);
      L.control.scale({ imperial: false, position: 'bottomleft' }).addTo(map);
      var markerLayer = L.layerGroup().addTo(map);
      // click on empty map area closes any open popup (we disabled the built-in
      // closeOnClick to keep PREV/NEXT button clicks from accidentally closing it).
      map.on('click', function () { map.closePopup(); });

      function renderMarkers(species) {
        markerLayer.clearLayers();
        var clusters = buildClusters(species);
        var bounds = [];
        Object.keys(clusters).forEach(function (k) {
          var c = clusters[k];
          var marker = L.marker(c.loc, { icon: clusterIcon(c.items.length) }).addTo(markerLayer);
          marker.bindPopup(popupContent(c.items, 0), { maxWidth: 280, minWidth: 240, autoPanPadding: [40, 60], closeOnClick: false });
          marker.on('popupopen', function (e) {
            wirePopupNav(e.popup, c.items, 0);
          });
          bounds.push(c.loc);
        });
        if (bounds.length) {
          map.fitBounds(bounds, { padding: [40, 40], maxZoom: 12 });
        } else {
          map.setView([20, 0], 2);
        }
      }

      function setMapVisible(visible) {
        var frame = document.querySelector('.animals-map-frame');
        frame.style.display = visible ? '' : 'none';
        if (visible) setTimeout(function () { map.invalidateSize(); }, 0);
      }

      function renderIndex() {
        document.getElementById('animals-detail').style.display = 'none';
        document.getElementById('animals-photos').style.display = 'none';
        setMapVisible(true);
        var grid = document.getElementById('animals-grid');
        grid.style.display = '';
        grid.innerHTML = '';
        var totalPhotos = 0, totalLocated = 0;
        animals.forEach(function (sp) {
          totalPhotos += sp.count;
          totalLocated += sp.located || 0;
          var card = document.createElement('div');
          card.className = 'animals-card';
          card.style.backgroundImage = 'url(' + sp.cover + ')';
          card.innerHTML =
            '<div class="animals-card-count">' + sp.count + '</div>' +
            (sp.located ? '<div class="animals-card-pin">📍 ' + sp.located + '</div>' : '') +
            '<div class="animals-card-info">' +
              '<span class="animals-card-zh">' + escHtml(sp.zh) + '</span>' +
              (sp.en ? '<span class="animals-card-en">' + escHtml(sp.en) + '</span>' : '') +
            '</div>';
          card.addEventListener('click', function () {
            setParam('species', sp.key);
            renderDetail(sp);
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          grid.appendChild(card);
        });
        document.getElementById('animals-stats').textContent =
          '共 ' + animals.length + ' 种 · ' + totalPhotos + ' 张照片 · ' + totalLocated + ' 张含坐标';
        renderMarkers(null);
      }

      function renderDetail(sp) {
        document.getElementById('animals-detail').style.display = '';
        document.getElementById('animals-grid').style.display = 'none';
        document.getElementById('animals-detail-zh').textContent = sp.zh;
        document.getElementById('animals-detail-en').textContent = sp.en || '';
        var hasMap = (sp.located || 0) > 0;
        document.getElementById('animals-detail-meta').textContent = hasMap
          ? sp.count + ' 张 · ' + sp.located + ' 张含坐标'
          : sp.count + ' 张 · 无坐标信息';
        document.getElementById('animals-stats').textContent = '';

        var photoGrid = document.getElementById('animals-photos');
        photoGrid.style.display = '';
        photoGrid.innerHTML = '';
        sp.photos.forEach(function (ph) {
          var tile = document.createElement('a');
          tile.className = 'animals-photo-tile';
          tile.style.backgroundImage = 'url(' + ph.thum + ')';
          tile.href = fullUrl + ph.dir + '?name=' + encodeURIComponent(ph.name);
          tile.title = (ph.desc || '').trim();
          photoGrid.appendChild(tile);
        });
        setMapVisible(hasMap);
        if (hasMap) renderMarkers(sp);
      }

      document.getElementById('animals-back').addEventListener('click', function () {
        setParam('species', null);
        renderIndex();
      });

      // corner brackets for the map frame
      var frame = document.querySelector('.animals-map-frame');
      ['corner-tl', 'corner-br'].forEach(function (cls) {
        var d = document.createElement('div');
        d.className = cls;
        frame.appendChild(d);
      });

      var initial = getParam('species');
      var initialSp = findSpecies(initial);
      if (initialSp) renderDetail(initialSp);
      else renderIndex();
    })();
  </script>
</section>
