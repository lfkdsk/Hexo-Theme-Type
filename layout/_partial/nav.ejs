<% var toc = toc(page.content, {
  class: 'itp-layer-toc',
  id: '',
  list_number: false,
  max_depth: 2,
  min_depth: 1,
}) %>
<% if (theme.schemes=='column' ){ %>
<%- partial('_partial/drawer') %>
<header id="header" class="itp-header noprn">
  <div id="appbar-index" class="mdui-appbar mdui-appbar-fixed itp-appbar_index mdui-shadow-0">
    <div id="toolbar-index" class="mdui-toolbar mdui-shadow-0" style="justify-content: center;">
      <% if (theme.schemes=='column' ){ %>
      <a class="mdui-btn mdui-btn-icon itp-drawer-btn itp-header-actions_menu" style="color: #fff" data-fancybox data-src="#nav_menu" href="javascript:;"><span class="material-icons-outlined">
          menu
        </span></a>
      <% } %>
      <a href="<%= url_for() %>" class="itp-header-title mdui-typo-title">
        <%- config.title %>
      </a>
      <div class="itp-nav-action">
        <% for (var i in config.nav) { %>
        <a href="<%- config.nav[i].link %>" class="mdui-btn itp-header-actions" style="color: #fff">
          <%- i %>
        </a>
        <% } %>
      </div>
      <div class="itp-nav-action">
        <% if (theme.search_btn==true){ %>
        <a href="/search.html" class="mdui-btn mdui-btn-icon itp-header-search-btn"><span class="material-icons-outlined">
            search
          </span></a>
        <% } %>
      </div>
    </div>
  </div>
</header>
<% } %>
<% if (theme.schemes=='m3' ){ %>
<div class="itp-float-bar">
  <!--所有页面都显示-->
  <a class="itp-float-bar-item rounded" href="<%= url_for() %>" title="<%- config.title %>">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="home"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- config.title %></span>
    <% } %>
  </a>
  <% if (page.layout !=='post' ){ %>
  <!--只在 **非文章** 页面显示-->
  <% var navKeys = Object.keys(config.nav || {}); %>
  <% navKeys.forEach(function(i, idx){ %>
  <a class="itp-float-bar-item rounded itp-nav-item itp-nav-idx-<%= idx %>" href="<%- config.nav[i].link %>" title="<%- i %>">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="<%- config.nav[i].icon %>"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- i %></span>
    <% } %>
  </a>
  <% }) %>
  <% if (navKeys.length > 3) { %>
  <a class="itp-float-bar-item rounded itp-nav-more" id="itp_nav_more" href="javascript:void(0)" title="More" aria-label="More">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="all-application"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span>···</span>
    <% } %>
  </a>
  <% } %>
  <% if (theme.search_btn == true){ %>
  <a href="/search/" class="itp-float-bar-item rounded itp-nav-search">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="search"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- __('search')%></span>
    <% } %>
  </a>
  <% } %>
  <%} else if (page.layout =='post' ){ %>
  <!--只在 **文章** 页面显示-->
  <a class="itp-float-bar-item rounded" onclick="scrollto(comment)" title="comment">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="comment"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- __('post_comment')%></span>
    <% } %>
  </a>
  <a class="itp-float-bar-item rounded" id="open_toc" onclick="OpenToc()" title="Table of contents">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="list"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- __('post_toc')%></span>
    <% } %>
  </a>
  <a class="itp-float-bar-item rounded" href="javascript:scroll(0,0)" title="to top">
    <% if (theme.nav_style=='icon' ){ %>
    <iconpark-icon class="navicon" name="top"></iconpark-icon>
    <%} else if (theme.nav_style =='text' ){ %>
    <span><%- __('post_totop')%></span>
    <% } %>
  </a>
  <% } %>

  <div class="itp-float-layer itp-toc-layer">
    <div class="clost-btn" style="display: flex;">
      <a class="itp-float-layer-close-btn" id="close_btn">
        <div class="close_btn_red">
        </div>
      </a>
    </div>
    <%-(toc) %>
  </div>
  <div class="itp-float-layer-bg layer-bg-nodisplay" id="close_layer"></div>
</div>
<% if (page.layout !=='post' && Object.keys(config.nav || {}).length > 3) { %>
<div class="itp-nav-sheet" id="itp_nav_sheet" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="itp-nav-sheet-handle"></div>
  <div class="itp-nav-sheet-grid">
    <% Object.keys(config.nav).forEach(function(i, idx) { if (idx >= 3) { %>
    <a class="itp-nav-sheet-item" href="<%- config.nav[i].link %>">
      <iconpark-icon class="navicon" name="<%- config.nav[i].icon %>"></iconpark-icon>
      <span><%- i %></span>
    </a>
    <% } }) %>
  </div>
</div>
<div class="itp-nav-sheet-bg" id="itp_nav_sheet_bg"></div>
<style>
  /* the SCSS .itp-float-bar .itp-float-bar-item rule is 2-class specificity,
     so we have to match it here or `display: inline-flex` wins on desktop */
  .itp-float-bar .itp-nav-more { display: none; }
  .itp-nav-sheet, .itp-nav-sheet-bg { display: none; }
  @media (max-width: 768px) {
    /* hide overflow nav items in the floatbar; sheet shows them all */
    .itp-float-bar .itp-nav-item.itp-nav-idx-3,
    .itp-float-bar .itp-nav-item.itp-nav-idx-4,
    .itp-float-bar .itp-nav-item.itp-nav-idx-5,
    .itp-float-bar .itp-nav-item.itp-nav-idx-6,
    .itp-float-bar .itp-nav-item.itp-nav-idx-7,
    .itp-float-bar .itp-nav-item.itp-nav-idx-8,
    .itp-float-bar .itp-nav-item.itp-nav-idx-9 { display: none; }
    .itp-float-bar .itp-nav-more { display: flex; }
  }
  .itp-nav-sheet-bg {
    position: fixed; inset: 0;
    background: rgba(20,20,20,.35);
    z-index: 1100;
    opacity: 0; transition: opacity .18s ease-out;
  }
  .itp-nav-sheet-bg.show { display: block; opacity: 1; }
  .itp-nav-sheet {
    position: fixed; left: 0; right: 0;
    bottom: calc(56px + env(safe-area-inset-bottom, 0px));
    z-index: 1101;
    background: var(--surface, #fff);
    border-top-left-radius: var(--radius-lg, 14px);
    border-top-right-radius: var(--radius-lg, 14px);
    box-shadow: 0 -8px 28px rgba(0,0,0,.18);
    padding: 8px 16px 20px;
    transform: translateY(100%);
    transition: transform .22s cubic-bezier(.2,.8,.2,1);
  }
  .itp-nav-sheet.show { display: block; transform: translateY(0); }
  .itp-nav-sheet-handle {
    width: 40px; height: 4px; border-radius: 2px;
    background: rgba(120,120,120,.35);
    margin: 6px auto 14px;
  }
  .itp-nav-sheet-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px 8px;
  }
  .itp-nav-sheet-item {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 8px 4px;
    color: var(--on-surface, #2f3a2f);
    text-decoration: none;
    font-size: 12px;
    border-radius: 10px;
    transition: background-color .15s ease;
  }
  .itp-nav-sheet-item:active { background: rgba(120,120,120,.12); }
  .itp-nav-sheet-item iconpark-icon { font-size: 24px; }
  @media (prefers-color-scheme: dark) {
    .itp-nav-sheet { background: #1d2326; }
    .itp-nav-sheet-item { color: #e6e0d0; }
    .itp-nav-sheet-bg { background: rgba(0,0,0,.55); }
  }
</style>
<script>
  (function () {
    var btn = document.getElementById('itp_nav_more');
    var sheet = document.getElementById('itp_nav_sheet');
    var bg = document.getElementById('itp_nav_sheet_bg');
    if (!btn || !sheet || !bg) return;
    function open() {
      sheet.style.display = 'block'; bg.style.display = 'block';
      // next frame so the transition runs
      requestAnimationFrame(function () { sheet.classList.add('show'); bg.classList.add('show'); });
      sheet.setAttribute('aria-hidden', 'false');
    }
    function close() {
      sheet.classList.remove('show'); bg.classList.remove('show');
      sheet.setAttribute('aria-hidden', 'true');
      setTimeout(function () { sheet.style.display = 'none'; bg.style.display = 'none'; }, 220);
    }
    btn.addEventListener('click', function (e) { e.preventDefault(); sheet.classList.contains('show') ? close() : open(); });
    bg.addEventListener('click', close);
    sheet.querySelectorAll('.itp-nav-sheet-item').forEach(function (a) {
      a.addEventListener('click', function () { close(); });
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && sheet.classList.contains('show')) close();
    });
  })();
</script>
<% } %>
<% } %>
<% if (theme.nav_style =='text' ){ %>
<style>
  a.itp-float-bar-item {
    line-height: 54px;
    padding: 0 6px;
  }
</style>
<% } %>
<style>
  .navicon {
    font-size: 18px;
    color: var(--main-black);
  }
</style>