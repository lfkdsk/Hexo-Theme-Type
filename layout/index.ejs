<section class="pjax-area">
  <div class="content-area album-area">
    <% if (theme.photography_page.slogan==true) { %>
      <div class="container gpro-slogan title">
        <% if (config.photography_page.slogan==true) { %>
          <%- config.photography_page.slogan_descr %>
            <% } else { %>
              <%- theme.photography_page.slogan_descr %>
                <% } %>
      </div>
      <% } %>
        <div id="year-button"></div>
        <div class="container gpro-container grid grid-cols-1 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          <% if (site.data.album) { %>
            <% for (var a in site.data.album) { %>
              <% var hidden=site.data.album[a].hidden %>
                <% if (!hidden) { %>
                  <a href="<%- url_for(site.data.album[a].url) %>">
                    <% var file=site.data.album[a].cover %>
                      <% var cover=config.thumbnail_url + file.substr(0, file.lastIndexOf(".")) + ".webp" %>
                        <div class="gpro-tile lazy" data-src="<%- cover %>">
                          <div class="gpro-tile-descr flex-col">
                            <div class="text-xl font-medium">
                              <%= a %>
                            </div>
                            <% var isEmpty=site.data.album[a].date==='' %>
                              <% if (!isEmpty) { %>
                                <div class="text-sm opacity-75">
                                  <%= moment(site.data.album[a].date).format(config.date_format) %>
                                </div>
                                <% } else { %>
                                  <div class="text-sm opacity-75">
                                    <%= site.data.album[a].subtitle %>
                                  </div>
                                <% } %>
                          </div>
                        </div>
                  </a>
                <% } %>
              <% } %>
            <% } %>
        </div>
  </div>
  <script>
    $(function () {
      $("div.lazy").lazyload();
      addYearEndSummaryLink(document.getElementById("year-button"), "<%- config.url %>")
    });
  </script>
  <style>
    body {
      background-color: var(--surface-2, #fafbfc);
    }

    @media (prefers-color-scheme: dark) {
      body { background-color: #121317; }
    }

    .album-area {
      margin-top: 120px;
      padding-left: 24px;
      padding-right: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .gpro-slogan {
      text-align: center;
      font-size: 44px;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.15;
      max-width: 820px;
      background: linear-gradient(120deg, var(--main-color, #71AFDD), var(--sub-color, #6CD9CE));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }

    .gpro-container {
      margin-top: 80px;
      gap: 18px;
      width: 100%;
      max-width: 1320px;
    }

    .gpro-tile {
      aspect-ratio: 3 / 2;
      background-position: center;
      background-size: cover;
      border-radius: var(--radius-lg, 16px);
      overflow: hidden;
      box-shadow: var(--shadow-1, 0 1px 3px rgba(15, 23, 42, 0.06));
      transition: transform var(--duration-3, 360ms) var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
                  box-shadow var(--duration-3, 360ms) var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
      min-height: 211px;
      will-change: transform;
    }

    .gpro-tile:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover, 0 18px 40px rgba(15, 23, 42, 0.16));
    }

    .gpro-tile-descr {
      position: relative;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      color: #fff;
      font-size: 14px;
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      text-overflow: clip;
      flex-direction: column;
      align-items: flex-start;
      transition: opacity var(--duration-2, 240ms) var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
      padding: 18px 20px;
      opacity: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 35%, rgba(0, 0, 0, 0.78) 100%);
    }

    .gpro-tile-descr > div:first-child {
      margin-top: auto;
    }

    .gpro-tile:hover .gpro-tile-descr {
      opacity: 1;
    }

    @media (max-width: 768px) {
      .gpro-tile-descr {
        opacity: 0.85;
      }

      .gpro-slogan {
        font-size: 30px;
      }

      .content-area {
        margin-top: 80px;
      }

      .gpro-container {
        margin-top: 48px;
        gap: 12px;
      }
    }
  </style>
</section>