<script src="js/html2canvas.min.js" defer></script>
<script src="js/mini-live-photo.js"></script>
<section class="pjax-area">
  <div class="content-area post-album <%- page.style %>-content-area">
    <div class="grid grid-cols-3">
      <div class="<%- page.style %>-pic gap-2 wrapper">
        <div id="all-pic" class="pic-area">
          <div id="pic-g" class="pic-item" />
          <img id="imgbox" class="pic-box nofancy" src="<%- page.photos[0].thum %>" />
        </div>
        <%- include('_partial/exif.ejs') %>
      </div>
      <p id="descbox" class="text-center text-xs hint-text" hidden> <%- page.photos[0].desc %> </p>
      <div class="album-list flex gap-2">
        <% for (var i in page.photos) { %>
          <% var p = page.photos[i]; %>
          <% var url = p.url; %>
          <% var name = p.name; %>
          <% var thum = p.thum; %>
          <% var share = p.share; %>
          <% var video = p.video; %>
          <%
          function searchPhoto(data, url) {
            for (var key in data) {
              if (key.toString() == url) {
                return data[key]
              }
            }
            return {}
          }
          %>
          <% var extra0 = searchPhoto(site.data.photos, share) %>
          <% var desc = extra0.desc %>
          <% var extra = JSON.parse(JSON.stringify(extra0)); %>
          <% extra.desc = null %>
          <a class="album-item lazy" id="<%- i %>"
            name="<%- name %>" rel="<%- url %>"
            desc="<%- desc %>"
            share="<%- share %>"
            video="<%- video %>"
            extra='<%- JSON.stringify(extra) %>'
            href="javascript:void(0);" onClick="changeimg(event)" data-src="<%- thum %>"
            aria-label="the photo <%- i %>"></a>
          <% } %>
      </div>
      <div class="text-center text-xs pt-2 hint-text"> </div>
    </div>
    <div class="album-info <%- page.style %>-info">
      <div class="album-info-main">
        <div class="album-info-btm">
          <% if ( page.location && page.location.length === 2 ) { %>
            <div class="album-location album-tool">
              <iconpark-icon name="local-two"></iconpark-icon><a href="<%- url_for() %>location?album=<%- page.url %>">MAP</a>
            </div>
          <% } %>
          <div class="album-share album-tool">
            <iconpark-icon name="share-three"></iconpark-icon><a id="share" href="javascript:void(0)"> Share Link </a>
          </div>
          <div class="album-share album-tool">
            <iconpark-icon name="down-picture"></iconpark-icon><a id="download" href="javascript:void(0)"> Download </a>
          </div>
          <div class="album-share album-tool">
            <iconpark-icon name="save"></iconpark-icon><a id="editor" href="javascript:void(0)"> Editor </a>
          </div>
          <div class="album-share album-tool">
            <iconpark-icon name="grid-nine"></iconpark-icon><a id="grid" href="javascript:void(0)"> Grid </a>
          </div>
        </div>
        <div class="album-title"><%- page.title %></div>
        <span class="album-subtitle">
          <% var useSub = page.subtitle !== '' && page.subtitle !== null %>
          <% console.log(page.subtitle) %>
          <% if (useSub) { %>
            —— <%= page.subtitle %><br />
            <% } else { %>
            —— <%= page.date.format(config.date_format) %><br />
          <% } %>
        </span>
        <span class="album-subtitle">
          <%= page.excerpt %>
        </span>
      </div>
      <div class="album-article article <%- page.style %>-article">
        <%- page.content %>
      </div>
    </div>
  </div>
  <% if ( theme.comment.use ) { %>
    <div id="comment" class="itp-m3-card album-comment">
      <%- partial('_partial/comment') %>
    </div>
  <% } %>
      </div>
      <script>
        var imageBox = document.getElementById("imgbox");
        var descBox = $("#descbox");
        var wrapper = $("#exif-wrapper");
        var exifParam = $("#exif-param");
        var exifMaker = $("#exif-maker");
        var exifDate = $("#exif-date");
        var exifLens = $("#exif-lens");
        var exifLogo = $("#exif-maker-logo");
        var exifAuthor = $("#exif-author");
        var normalWrapper = $("#normal-wrapper");
        var normalData = $("#no-exif-data");
        var name = getParam('name');
        var editor = $("#editor");
        imgno = 0;
        imgLink = imageBox.src;
        // Monotonic token: guards against a slow earlier high-res load finishing
        // after a newer photo was selected and overwriting it.
        var imgLoadToken = 0;
        function changeExifData(v) {
          if (Object.keys(v.exif_data).length === 0) {
            wrapper.hide();
            normalWrapper.show();
            normalData.text("Shot By " + "<%- config.author %>");
          } else {
            wrapper.show();
            normalWrapper.hide();
            wrapperData(v, "<%- config.author %>");
          }
        }

        function changeImageWith(target) {
          imgno = target.getAttribute('id');
          imgLink = target.getAttribute('rel');
          name = target.getAttribute('name');
          var desc = target.getAttribute('desc');
          var thum = target.getAttribute('data-src');
          var video = target.getAttribute('video');
          var v = JSON.parse(target.getAttribute('extra'));
          // Progressive "blur-up": show the picked photo's thumbnail immediately
          // (instant feedback that the click landed on the right photo), softly
          // blurred, then decode the full-res in the background and swap to it.
          // The blur is now modest and `.pic-item { overflow:hidden }` clips it to
          // the frame — the old code used blur(50px) with no clip, so the smear
          // spilled past the 相框 and sat there for the whole multi-MB download.
          var myToken = ++imgLoadToken;
          imageBox.src = thum;
          imageBox.classList.add('is-loading');
          var highResImage = new Image();
          var finishSwap = function(src) {
            if (myToken !== imgLoadToken) return; // a newer selection superseded us
            imageBox.src = src;
            imageBox.classList.remove('is-loading');
            // preload next image into browser cache
            var nextIdx = Number(imgno) + 1;
            if (nextIdx < len) {
              var nextEl = document.getElementById(nextIdx);
              if (nextEl) {
                var prefetch = new Image();
                prefetch.src = nextEl.getAttribute('rel');
              }
            }
          };
          highResImage.onload = function() {
            // Decode off the main thread when supported so the swap doesn't hitch.
            if (highResImage.decode) {
              highResImage.decode().then(function() { finishSwap(imgLink); },
                                        function() { finishSwap(imgLink); });
            } else {
              finishSwap(imgLink);
            }
          };
          // Never get stuck on a stale/blurred frame: fall back to the thumbnail.
          highResImage.onerror = function() { finishSwap(thum); };
          highResImage.src = imgLink;
          imageBox.setAttribute("share", target.getAttribute('share'));
          var imageFancy = imageBox.parentElement;
          imageFancy.setAttribute("href", imgLink);

          var picg = document.getElementById('pic-g');
          attachLivePhoto(picg, false, '');
          attachLivePhoto(picg, video !== '', video);
          // keep the open fullscreen viewer in sync when navigating (arrow keys):
          // swap the displayed fancybox <img> in place — no transform reset, so it
          // stays HDR. (Only present while the Fancybox viewer is open.)
          var fbImg = document.querySelector('.fancybox-hdr .fancybox__image');
          if (fbImg) fbImg.src = imgLink;
          target.scrollIntoView({ behavior: "smooth", block: "end", inline: "nearest" })
          descBox.text(imgno.desc);
          imageBox.title = desc;
          changeExifData(v);
          updateParams(name);
        }
        function cheangeImageInSelector() {
          changeImageWith(document.getElementById(imgno))
        }
        function changeimg() {
          changeImageWith(event.target)
        };
        function changeImageWithName(name) {
          var value = $(`[name='${name}']`)[0];
          changeImageWith(value)
        };
        const len = +'<%= page.photos.length %>'
        if (name !== "" && name !== null && name !== 'null') {
          changeImageWithName(name)
        } else {
          var value = $(`#0`)[0];
          name = value.getAttribute('name');
          imgLink = value.getAttribute('rel');
          imageBox.title = value.getAttribute('desc');
          var v = JSON.parse(value.getAttribute('extra'));
          changeExifData(v);
          imageBox.setAttribute("share", value.getAttribute('share'));
          // progressively load full-res for initial image without blur flash
          const initHighRes = new Image();
          initHighRes.src = imgLink;
          initHighRes.onload = function() {
            imageBox.src = initHighRes.src;
            // preload second image
            var nextEl = document.getElementById(1);
            if (nextEl) {
              var prefetch = new Image();
              prefetch.src = nextEl.getAttribute('rel');
            }
          };
        }

        $('#download').click(function () {
          var node = document.getElementById('all-pic');
          html2canvas(node, {
            useCORS: true,
            allowTaint: true,
            scrollX: 0,
            scrollY: 0,
          }).then(function (canvas) {
            simulateDownloadImageClick(canvas.toDataURL('image/png'),  name + '.png');
          });
        });
        editor.click(function () {
          window.open('<%- config.url %>/editor?file=' + encodeURIComponent(imgLink));
        })
        // key
        window.onkeydown = function album_hotkey() {
          //[键盘快捷键] 左箭头 上一张
          if (event.keyCode === 37) {
            imgno = imgno - 1;
            if (imgno < 0) {
              imgno = 0;
            }
            cheangeImageInSelector();
          };
          //[键盘快捷键] 右箭头 下一张
          if (event.keyCode === 39) {
            imgcount = len - 1
            imgno = Number(imgno) + 1;
            if (imgno > imgcount) {
              imgno = imgcount
            }
            imgno = Number(imgno)
            console.log(imgno)
            cheangeImageInSelector();
          };
          //[键盘快捷键] 上箭头 恢复到第一张
          if (event.keyCode === 38) {
            imgno = 0;
            cheangeImageInSelector();
          };
        };
        $("#share").on('click', function() {
          var imageBox = document.getElementById("imgbox");
          copyToClipboard('<%- full_url_for() %>' + "photo?name=" + imageBox.getAttribute('share'));
        });
        $("#grid").on('click', function() {
          window.open('<%- config.root %>grid-all?album=' + encodeURIComponent('<%- page.url %>'));
        });

        // HDR-safe "放大" (enlarge) viewer, built on the theme's own Fancybox
        // instead of a hand-rolled overlay. Fancybox normally tone-maps HDR
        // (gain-map) photos to SDR: its pan/zoom and open/close animations apply a
        // transform/opacity to the image, forcing the browser to composite through
        // an SDR buffer. So we open a *single* image with those animations and zoom
        // turned off, under `mainClass: 'fancybox-hdr'`, and the `.fancybox-hdr`
        // CSS below forbids transform/filter/opacity on the whole image chain — the
        // photo keeps its HDR headroom, matching the inline <img>. Zoom stays off on
        // purpose: any scale() would re-introduce the transform and drop to SDR.
        // The scoping leaves the theme's other Fancybox galleries (post / gallery
        // pages) with their normal zoom.
        (function () {
          // "Transform first, then bring back HDR." A CSS transform forces the
          // browser to composite the photo through an SDR buffer (that's why zoom
          // tone-maps HDR → SDR). So we let Fancybox's Panzoom zoom freely — SDR
          // only while you're actively zoomed — and the instant it settles back to
          // "fit" (an identity transform) we replace that transform with `none`,
          // dropping the GPU layer so the browser re-renders the photo in HDR.
          // Net: HDR at rest, SDR only mid-zoom. (Verify the HDR part on an HDR
          // display — removing the transform is the lever; the browser does the
          // rest.)
          function snapToHDR(root) {
            ['.fancybox__content', '.fancybox__image'].forEach(function (sel) {
              var el = root.querySelector(sel);
              if (!el) return;
              var tr = getComputedStyle(el).transform;
              if (tr === 'none') return;
              var m = /matrix\(([^)]+)\)/.exec(tr);
              if (!m) return;
              var p = m[1].split(',').map(parseFloat);
              var identity = Math.abs(p[0] - 1) < 1e-3 && Math.abs(p[1]) < 1e-3 &&
                             Math.abs(p[2]) < 1e-3 && Math.abs(p[3] - 1) < 1e-3 &&
                             Math.abs(p[4]) < 0.5 && Math.abs(p[5]) < 0.5;
              if (identity) el.style.transform = 'none'; // identity → drop layer → HDR
            });
          }
          function watchHDR(root) {
            if (!root || root.__hdr) return;
            root.__hdr = true;
            var t;
            new MutationObserver(function () {
              clearTimeout(t);
              t = setTimeout(function () { snapToHDR(root); }, 140);
            }).observe(root, { attributes: true, subtree: true, attributeFilter: ['style'] });
            setTimeout(function () { snapToHDR(root); }, 60);
          }
          imageBox.style.cursor = 'zoom-in';
          imageBox.addEventListener('click', function () {
            if (!window.Fancybox) return;
            Fancybox.show([{ src: imgLink, type: 'image' }], {
              showClass: false,   // open instantly (HDR from the first frame)
              hideClass: false,
              dragToClose: false,
              mainClass: 'fancybox-hdr',
              keyboard: { Escape: 'close' },
              Carousel: { transition: false },
              on: { done: function () { watchHDR(document.querySelector('.fancybox-hdr')); } }
            });
          });
        })();
      </script>
      <style>
        body {
          background-color: #fff;
        }

        .fullscreen-pic {
          grid-column: span 3 / span 3;
        }

        .fullscreen-info {
          grid-column: span 3 / span 3;
        }

        .album-comment {
          max-width: 800px;
          margin: 0 auto;
        }

        .album-article {
          font-size: 1.2rem;
        }

        .hint-text {
          color: black;
          opacity: 60%;
          padding-top: 4px;
        }

        .pic-item {
          background-color: black;
          background-size: cover;
          background-position: center;
          transition: all .1s ease-in-out;
          min-height: 200px;
          aspect-ratio: 3 / 2;
          /* Clip to the frame. Without this, anything inside that paints past the
             box escapes the 相框 — most visibly a `filter: blur()` halo (a blur
             radius extends the paint area by ~that many px on every side), but
             also the live-photo <video>. Keep the frame strictly self-contained. */
          overflow: hidden;
        }

        /* Progressive blur-up while the full-res photo loads (see changeImageWith).
           A modest radius — the old code used 50px, which read as a broken render;
           `.pic-item { overflow:hidden }` keeps it inside the 相框. `.pic-box`'s
           0.1s transition makes the sharpen-in when the full-res arrives smooth. */
        .pic-box.is-loading {
          filter: blur(16px);
        }

        .pic-item > a {
          width: 100%;
          height: 100%;
          overflow: hidden;
          display: inline-block;
        }

        .pic-box {
          transition: all .1s ease-in-out;
          display: inline-block;
          width: 100%;
          height: 100%;
          object-fit: contain;
          margin: 0 auto;
        }

        .album-info {
          flex-direction: column;
          justify-content: space-between;
          color: var(--main-black);
        }

        .album-title {
          font-size: 2em;
        }

        .album-subtitle {
          font-size: 1.2em;
          opacity: 0.8;
        }


        .album-tool {
          display: inline-flex;
          font-size: .8em;
          color: #71afdd;
          gap: 4px;
          padding-bottom: 4px;
        }

        .album-list {
          padding-top: 12px;
          overflow-x: scroll;
        }

        .album-item {
          background-color: black;
          aspect-ratio: 1 / 1;
          border: 0.8px solid black;
          border-radius: 2px;
          min-height: 100px;
          min-width: 100px;
          background-size: cover;
          background-position: center;
        }

        @media (max-width: 768px) {
          .content-area {
            max-width: 100vw;
          }

          .pic-area {
            grid-column: span 3 / span 3;
            padding: 8px 8px 0 8px;
          }

          .default-pic {
            grid-column: span 3 / span 3;
          }

          .album-info {
            grid-column: span 3 / span 3;
            padding: 12px;
          }

          .album-article {
            padding: 2px;
          }

          .album-title {
            font-size: 1.5em;
          }

          .wrapper {
            padding: 8px;
          }

          iframe {
            max-width: 100%;
          }
        }

        @media (min-width: 769px) {
          .content-area {
            max-width: 92%;
            margin: 0 auto;
            padding: 115px 16px 16px 16px;
          }

          .album-article {
            margin-top: 2px;
          }

          .default-article {
            max-height: 500px;
            overflow-y: scroll;
          }

          .default-info {
            padding-left: 16px;
          }

          .pic-area {
            grid-column: span 2 / span 2;
            padding: 12px 12px 4px 12px;
          }

          #exif-wrapper {
            margin-top: 4px;
          }

          .default-pic {
            grid-column: span 2 / span 2;
          }
        }

        @media (min-width: 1304px) {
          .content-area {
            max-width: 1400px;
          }

          .fullscreen-content-area {
            max-width: 100vh;
          }
        }

        @media (prefers-color-scheme: dark) {
          .album-info {
            color: #fff;
          }

          .album-tool {
            color: #bdbdbd;
          }

          .hint-text {
            color: white;
            opacity: 80%;
          }

          .pic-item {
            background-color: black;
          }

          .album-item {
            background-color: black;
          }

          .album-item {
            border: 0.8px solid white;
          }
        }

        /* HDR Fancybox "放大" viewer (opened on main-image click). Zoom is left
           ENABLED; HDR is managed in JS (see the Fancybox.show call above): the
           image keeps Panzoom's transform while zoomed (SDR), and is snapped back
           to transform:none once it settles at fit so the browser restores HDR.
           No transform/filter/opacity is forced here — that would block the zoom.
           Scoped to `.fancybox-hdr` (our mainClass) so the theme's other Fancybox
           galleries are untouched. We still keep a couple of safety rails: never
           let a filter/opacity sneak onto the resting image. */
        .fancybox-hdr .fancybox__image {
          filter: none;
        }

      </style>
</section>